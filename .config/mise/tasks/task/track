#!/usr/bin/env zsh
#MISE description="Create a timewarrior entry linked to a taskwarrior task"
#MISE quiet=true
#USAGE arg "<uuid>" help="Taskwarrior task UUID (short form OK)"
#USAGE arg "[when]..." help="Optional time/range, passed to timew (e.g. '3am' or 'yesterday 3am - 11am')" var=#true
#USAGE complete "uuid" run=#"task export 2>/dev/null | jq -r '.[] | "\(.uuid | split("-")[0]):\(.description)"'"# descriptions=#true

set -eu
eval "when=(${usage_when:-})"

uuid=${usage_uuid?}
desc=$(task _get "$uuid.description")
[[ -n $desc ]] || { echo "Error: Task '$uuid' not found." >&2; exit 1 }
proj=$(task _get "$uuid.project")
tags=$(task _get "$uuid.tags" | tr ',' ' ')

tags_args=($desc)
[[ -n $proj ]] && tags_args+=($proj)
[[ -n $tags ]] && tags_args+=(${=tags})

# A bare `-` token means it's a range → `track`. Otherwise → `start`.
if (( ${when[(I)-]} )); then
  timew track $when $tags_args
else
  timew start $when $tags_args
fi
