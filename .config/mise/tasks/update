#!/usr/bin/env bash
#MISE description="Run all update:* in parallel tmux panes"
#MISE quiet=true

set -euo pipefail
source "$(cd "$(dirname "$0")" && pwd)/utils/colors.sh"

EL=$'\033[K'
TMUX_WINDOW="mise-updates"

check_exists() {
  case "$1" in
  tmux-tmp) [[ -d "$HOME/.config/tmux/plugins/tpm" ]] ;;
  yazi-plugins) command -v ya &>/dev/null ;;
  zinit | zsh-plugins) [[ -d "$HOME/.local/share/zinit/zinit.git" ]] ;;
  *) command -v "$1" &>/dev/null ;;
  esac
}

# ── Gather available tasks ───────────────────────────────────────────────────

mapfile -t all_tasks < <(mise tasks ls --raw | awk '$1 ~ /^update:.+/ && $1 != "update" {print $1}')

available=()
for task in "${all_tasks[@]}"; do
  name="${task#update:}"
  if check_exists "$name"; then
    available+=("$task")
  else
    printf "${YELLOW}${BOLD}[%s]${NC} not found, skipping.\n" "$task"
  fi
done
((${#available[@]})) || {
  printf "${RED}${BOLD}No updatable tools found.${NC}\n" >&2
  exit 1
}

# ── Interactive selection ────────────────────────────────────────────────────

declare -A selected
for task in "${available[@]}"; do selected["$task"]=1; done

cursor=0
sudo_pass=""
max=$((${#available[@]} - 1))

cleanup() { tput cnorm rmcup 2>/dev/null || printf '\033[?25h\033[?1049l'; }
tput smcup civis 2>/dev/null || printf '\033[?1049h\033[?25l'
trap cleanup EXIT

print_menu() {
  local buf='\033[H'
  buf+="${BOLD}╭─────────────────────────────────────────╮${NC}${EL}\n"
  buf+="${BOLD}│        Select updates to run            │${NC}${EL}\n"
  buf+="${BOLD}╰─────────────────────────────────────────╯${NC}${EL}\n${EL}\n"

  local i=0 ptr icon color
  for task in "${available[@]}"; do
    [[ $i -eq $cursor ]] && ptr="${BOLD}▸${NC} " || ptr="  "
    if [[ ${selected["$task"]} -eq 1 ]]; then
      icon="󰡖" color="${CYAN}${BOLD}"
    else
      icon="󰄱" color="${RED}${BOLD}"
    fi
    buf+="  ${ptr}${color}${icon}${NC} ${task#update:}${EL}\n"
    ((i++)) || true
  done

  buf+="${EL}\n"
  # Show sudo warning only if apt is selected
  for task in "${available[@]}"; do
    if [[ "${task#update:}" == "apt" && ${selected["$task"]} -eq 1 ]]; then
      buf+="  ${YELLOW}${BOLD}sudo required${NC} - password will be requested${EL}\n"
      break
    fi
  done
  buf+="${EL}\n"

  buf+="  ${BOLD}Space${NC}) Toggle    "
  buf+="${BOLD}a${NC}) Toggle all    "
  buf+="${GREEN}${BOLD}Enter${NC}) Confirm    "
  buf+="${RED}${BOLD}q${NC}) Quit${EL}\033[J"

  printf '%b' "$buf"
}

read_key() {
  local key
  IFS= read -rsn1 key
  if [[ "$key" == $'\033' ]]; then
    local seq
    IFS= read -rsn1 -t 0.01 seq
    if [[ "$seq" == "[" ]]; then
      IFS= read -rsn1 -t 0.01 seq
      case "$seq" in A) key=UP ;; B) key=DOWN ;; *) key=ESC ;; esac
    else key=ESC; fi
  fi
  printf '%s' "$key"
}

toggle() {
  local t="${available[$cursor]}"
  selected["$t"]=$((selected["$t"] ^ 1))
}

while true; do
  print_menu
  case "$(read_key)" in
  k | UP) ((cursor > 0)) && ((cursor--)) || true ;;
  j | DOWN) ((cursor < max)) && ((cursor++)) || true ;;
  " ") toggle ;;
  a | A)
    local_all=1
    for task in "${available[@]}"; do [[ ${selected["$task"]} -eq 0 ]] && local_all=0 && break; done
    for task in "${available[@]}"; do selected["$task"]=$((local_all ^ 1)); done
    ;;
  q | ESC)
    cleanup
    trap - EXIT
    printf "${RED}${BOLD}Cancelled.${NC}\n"
    exit 1
    ;;
  "")
    local_sudo=0
    for task in "${available[@]}"; do
      [[ "${task#update:}" == "apt" && ${selected["$task"]} -eq 1 ]] && local_sudo=1 && break
    done
    if [[ $local_sudo -eq 1 ]]; then
      tput cnorm 2>/dev/null
      printf "\n\n  sudo password: "
      read -rs sudo_pass
      [[ -z "$sudo_pass" ]] && {
        tput civis 2>/dev/null
        continue
      }
    fi
    break
    ;;
  esac
done

cleanup
trap - EXIT

# ── Build chosen list ────────────────────────────────────────────────────────

chosen=()
for task in "${available[@]}"; do
  [[ ${selected["$task"]} -eq 1 ]] && chosen+=("$task")
done
((${#chosen[@]})) || {
  printf "${RED}${BOLD}Nothing selected.${NC}\n" >&2
  exit 1
}

# ── Launch tmux panes ────────────────────────────────────────────────────────

make_cmd() {
  local task="$1" name="${task#update:}" cmd="mise run $task"
  if [[ "$name" == "apt" && -n "$sudo_pass" ]]; then
    cmd="printf '%s\n' '$(printf '%s' "$sudo_pass" | sed "s/'/'\\\\''/g")' | sudo -S true 2>/dev/null; ${cmd}"
  fi
  printf 'printf "\\n\\033[1;36m── %s ──\\033[0m\\n"; %s && printf "\\n\\033[1;32m✓ %s succeeded\\033[0m\\n" || printf "\\n\\033[1;31m✗ %s failed\\033[0m\\n"; printf "\\n(press any key to close)"; read -r -n 1' \
    "$name" "$cmd" "$name" "$name"
}

if [[ -n "${TMUX:-}" ]]; then
  session="$(tmux display-message -p '#S')"
  tmux new-window -t "$session" -n "$TMUX_WINDOW" "$(make_cmd "${chosen[0]}")"
  target="$session:$TMUX_WINDOW"
else
  tmux kill-session -t "$TMUX_WINDOW" 2>/dev/null || true
  tmux new-session -d -s "$TMUX_WINDOW" -x "$(tput cols)" -y "$(tput lines)" \
    "$(make_cmd "${chosen[0]}")"
  target="$TMUX_WINDOW"
fi

for task in "${chosen[@]:1}"; do
  tmux split-window -t "$target" "$(make_cmd "$task")"
  tmux select-layout -t "$target" tiled >/dev/null
done
tmux select-layout -t "$target" tiled >/dev/null
tmux select-pane -t "$target.{top-left}"
sudo_pass=""

[[ -n "${TMUX:-}" ]] && tmux select-window -t "$target" || tmux attach-session -t "$TMUX_WINDOW"
