#!/usr/bin/env bash
#MISE description="Run all update:*"
#MISE quiet=true

source "$(cd "$(dirname "$0")" && pwd)/utils/colors.sh"
T_OK="${GREEN}${BOLD}"
T_WARNING="${YELLOW}${BOLD}"
T_ERROR="${RED}${BOLD}"
T_PROGRAM="${CYAN}${BOLD}"

CONTINUE_ALL=""

# Helper to check if update target exists
check_exists() {
  local target="$1"
  case "$target" in
  zinit) [ -d "$HOME/.local/share/zinit/zinit.git" ] ;;
  tmux) [ -d "$HOME/.config/tmux/plugins/tpm" ] ;;
  yazi) command -v ya >/dev/null 2>&1 ;;
  *) command -v "$target" >/dev/null 2>&1 ;;
  esac
}

tasks=$(mise tasks ls --raw | awk '{print $1}' | grep '^update:' | grep -v '^update$')

for task in $tasks; do
  name="${task#update:}"

  if ! check_exists "$name"; then
    printf "${T_WARNING}[update:%s]${NC} not found, skipping.\\n" "$name"

    continue
  fi

  if [ -z "$CONTINUE_ALL" ]; then
    while true; do
      printf "${T_PROGRAM}[update:%s]${NC} [${T_OK}Y${NC}es/${T_OK}A${NC}ll/${T_WARNING}N${NC}o/${T_ERROR}C${NC}ancel] " "$name"
      read -r -n 1 input
      case "$input" in
      [yY]*)
        printf "\\n"
        break
        ;;
      [aA]*)
        CONTINUE_ALL="true"
        printf "\\n"
        break
        ;;
      [nN]*)
        printf "\\n"
        continue 2
        ;;
      [cC]*)
        printf "\\n[${T_ERROR}CANCELLED${NC}]\\n"
        exit 1
        ;;
      *) printf "\\nInvalid input. Please enter Y, A, N or C.\\n" ;;
      esac
    done
  fi

  if mise run "$task"; then
    printf "[${T_OK}SUCCEEDED${NC}]\\n"
  else
    printf "[${T_ERROR}FAILED${NC}]\\n"
  fi
done
