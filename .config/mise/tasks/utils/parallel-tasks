#!/usr/bin/env zsh

# Interactive task picker + parallel tmux pane launcher.
# Source this from a mise task script — do not execute directly.
#
# Usage:
#   PREFIX="update"                                    # mise task prefix (update, clean, ...)
#   MENU_TITLE="Select updates to run            │"    # box title (pad to 33 chars + trailing │)
#   TMUX_WINDOW="mise-updates"                         # tmux window name
#   check_exists() { ... }                             # optional: custom tool existence check
#   source "${0:A:h}/utils/parallel-tasks"

source "${0:A:h}/colors"

T_OK="${GREEN}${BOLD}"
T_WARNING="${YELLOW}${BOLD}"
T_ERROR="${RED}${BOLD}"
T_PROGRAM="${CYAN}${BOLD}"

die() {
  printf "${T_ERROR}%s${NC}\n" "$1" >&2
  exit 1
}

# Default check_exists if caller didn't define one
(( ${+functions[check_exists]} )) || check_exists() { command -v "$1" >/dev/null 2>&1; }

# ── Gather available tasks ───────────────────────────────────────────────────

available=()
for task in "${(@f)$(mise tasks ls --raw | awk -v p="^${PREFIX}:.+" '$1 ~ p && $1 != "'"${PREFIX}"'" {print $1}')}"; do
  if check_exists "${task#${PREFIX}:}"; then
    available+=("$task")
  else
    printf "${T_WARNING}[%s]${NC} not found, skipping.\n" "$task"
  fi
done

(( $#available )) || die "No ${PREFIX} tasks found."

# Detect which tasks require sudo (single batch call via jq)
typeset -A sudo_tasks
for task in "${(@f)$(mise tasks ls --json 2>/dev/null \
  | jq -r '.[] | select(any(.run[]?; contains("sudo"))) | .name')}"; do
  sudo_tasks[$task]=1
done

# Associative array: selected["task:name"] = 0 or 1
typeset -A selected
for task in $available; do selected[$task]=1; done

# Check if any currently selected task requires sudo
check_needs_sudo() {
  needs_sudo=0
  for task in ${(k)sudo_tasks}; do
    if (( ${+selected[$task]} )) && (( selected[$task] )); then
      needs_sudo=1
      return
    fi
  done
}

# ── Interactive picker ───────────────────────────────────────────────────────

cursor=1  # zsh arrays are 1-indexed
needs_sudo=0
sudo_pass=""

check_needs_sudo

# Alternate screen buffer preserves terminal scrollback
cleanup_screen() { echoti rmcup 2>/dev/null || printf '\033[?1049l'; }
echoti smcup 2>/dev/null || printf '\033[?1049h'
echoti civis 2>/dev/null
trap cleanup_screen EXIT

local -r pfx_cursor="  ${BOLD}▸${NC} "
local -r pfx_normal="    "

# Buffered to a single printf '%b' call to avoid visible redraws
print_menu() {
  local el=$'\033[K'
  local buf='\033[H'

  buf+="${BOLD}╭─────────────────────────────────────────╮${NC}${el}\n"
  buf+="${BOLD}│        ${MENU_TITLE}${NC}${el}\n"
  buf+="${BOLD}╰─────────────────────────────────────────╯${NC}${el}\n${el}\n"

  local i=0 name pfx icon color
  for task in $available; do
    (( ++i ))
    name="${task#${PREFIX}:}"
    if (( i == cursor )); then pfx=$pfx_cursor; else pfx=$pfx_normal; fi
    if (( selected[$task] )); then icon="󰡖" color=$T_PROGRAM; else icon="󰄱" color=$T_ERROR; fi
    buf+="${pfx}${color}${icon}${NC} ${name}${el}\n"
  done

  buf+="${el}\n"
  if (( needs_sudo )); then
    buf+="  ${T_WARNING}sudo required${NC} - password will be requested${el}\n"
  fi
  buf+="${el}\n"

  buf+="  ${BOLD}Space${NC}) Toggle    "
  buf+="${BOLD}a${NC}) Toggle all    "
  buf+="${T_OK}${BOLD}Enter${NC}) Confirm    "
  buf+="${T_ERROR}q${NC}) Quit${el}"
  buf+='\033[J'

  printf '%b' "$buf"
}

# Reads one keypress into REPLY, translating arrow escape sequences
read_key() {
  read -rsk1 REPLY
  if [[ "$REPLY" == $'\033' ]]; then
    local seq
    read -rsk1 -t 0.01 seq
    if [[ "$seq" == "[" ]]; then
      read -rsk1 -t 0.01 seq
      case "$seq" in
      A) REPLY="UP" ;; B) REPLY="DOWN" ;; *) REPLY="ESC" ;;
      esac
    else
      REPLY="ESC"
    fi
  fi
}

# j/k, arrows, space, a, q/Esc, Enter
while true; do
  print_menu
  read_key

  case "$REPLY" in
  k | UP) (( cursor = cursor > 1 ? cursor - 1 : 1 )) ;;
  j | DOWN) (( cursor = cursor < $#available ? cursor + 1 : $#available )) ;;
  " ")
    local task=$available[$cursor]
    selected[$task]=$(( !selected[$task] ))
    check_needs_sudo
    ;;
  a)
    local all_on=1
    for task in $available; do
      (( selected[$task] )) || { all_on=0; break; }
    done
    local val=$(( !all_on ))
    for task in $available; do selected[$task]=$val; done
    check_needs_sudo
    ;;
  q | ESC)
    echoti cnorm 2>/dev/null
    cleanup_screen
    trap - EXIT
    printf "${T_ERROR}Cancelled.${NC}\n"
    exit 1
    ;;
  $'\n')
    # On confirm, prompt for sudo password if check_needs_sudo set the flag
    if (( needs_sudo )); then
      echoti cnorm 2>/dev/null
      printf "\n\n  ${T_ERROR}sudo${NC} password: "
      read -rs sudo_pass
      if [[ -z "$sudo_pass" ]]; then
        echoti civis 2>/dev/null
        continue
      fi
    fi
    break
    ;;
  esac
done

echoti cnorm 2>/dev/null
cleanup_screen
trap - EXIT

# ── Build chosen list ────────────────────────────────────────────────────────

chosen=()
for task in $available; do
  if (( selected[$task] )); then chosen+=("$task"); fi
done
(( $#chosen )) || die "Nothing selected."

# ── Launch tmux panes ────────────────────────────────────────────────────────

# Builds the shell command string that runs inside each tmux pane:
# prints a title, runs the task, shows 󰸞/󱎘 result, waits for keypress
make_cmd() {
  local task="$1"
  local name="${task#${PREFIX}:}"
  local cmd="mise run $task"

  # Pre-authenticate sudo if password was provided and task needs it
  if (( ${+sudo_tasks[$task]} )) && [[ -n "$sudo_pass" ]]; then
    cmd="printf '%s\n' ${(qq)sudo_pass} | sudo -S true 2>/dev/null; $cmd"
  fi

  printf 'printf "\\n\\033[1;36m── %s ──\\033[0m\\n"; %s && printf "\\n\\033[1;32m󰸞 %s succeeded\\033[0m\\n" || printf "\\n\\033[1;31m󱎘 %s failed\\033[0m\\n"; printf "\\n(press Enter to close)"; read -rsk1' \
    "$name" "$cmd" "$name" "$name"
}

# Open a tmux window (or session if not in tmux), then split into tiled panes
local -ri inside_tmux=${+TMUX}

if (( inside_tmux )); then
  current_session="$(tmux display-message -p '#S')"
  tmux new-window -t "$current_session" -n "$TMUX_WINDOW" "$(make_cmd "$chosen[1]")"
  target="$current_session:$TMUX_WINDOW"
else
  tmux kill-session -t "$TMUX_WINDOW" 2>/dev/null || true
  tmux new-session -d -s "$TMUX_WINDOW" -x "$(echoti cols)" -y "$(echoti lines)" \
    "$(make_cmd "$chosen[1]")"
  target="$TMUX_WINDOW"
fi

# Each split rebalances with tiled layout to prevent "pane too small" errors
for task in ${chosen[2,-1]}; do
  tmux split-window -t "$target" "$(make_cmd "$task")"
  tmux select-layout -t "$target" tiled >/dev/null
done

tmux select-layout -t "$target" tiled >/dev/null
tmux select-pane -t "$target.{top-left}"
sudo_pass=""

if (( inside_tmux )); then
  tmux select-window -t "$target"
else
  tmux attach-session -t "$TMUX_WINDOW"
fi
