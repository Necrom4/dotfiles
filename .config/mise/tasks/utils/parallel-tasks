#!/usr/bin/env bash

# Interactive task picker + parallel tmux pane launcher.
# Source this from a mise task script — do not execute directly.
#
# Usage:
#   PREFIX="update"                                    # mise task prefix (update, clean, ...)
#   MENU_TITLE="Select updates to run            │"    # box title (pad to 33 chars + trailing │)
#   TMUX_WINDOW="mise-updates"                         # tmux window name
#   check_exists() { ... }                             # optional: custom tool existence check
#   source "$(cd "$(dirname "$0")" && pwd)/utils/parallel-tasks"

source "$(cd "$(dirname "$0")" && pwd)/utils/colors.sh"

T_OK="${GREEN}${BOLD}"
T_WARNING="${YELLOW}${BOLD}"
T_ERROR="${RED}${BOLD}"
T_PROGRAM="${CYAN}${BOLD}"

die() {
  printf "${T_ERROR}%s${NC}\n" "$1" >&2
  exit 1
}

# Default check_exists if caller didn't define one
if ! declare -f check_exists >/dev/null 2>&1; then
  check_exists() { command -v "$1" >/dev/null 2>&1; }
fi

# ── Gather available tasks ───────────────────────────────────────────────────

mapfile -t all_tasks < <(mise tasks ls --raw | awk -v p="^${PREFIX}:.+" '$1 ~ p && $1 != "'"${PREFIX}"'" {print $1}')

available=()
for task in "${all_tasks[@]}"; do
  name="${task#${PREFIX}:}"
  if check_exists "$name"; then
    available+=("$task")
  else
    printf "${T_WARNING}[%s]${NC} not found, skipping.\n" "$task"
  fi
done

[[ ${#available[@]} -eq 0 ]] && die "No ${PREFIX} tasks found."

# Detect which tasks require sudo by inspecting their script content
declare -A task_needs_sudo
for task in "${available[@]}"; do
  if mise tasks "$task" --json 2>/dev/null | grep -q "sudo"; then
    task_needs_sudo["$task"]=1
  fi
done

# Check if any currently selected task requires sudo
check_needs_sudo() {
  needs_sudo=0
  for task in "${available[@]}"; do
    if [[ ${task_needs_sudo["$task"]:-0} -eq 1 ]] && [[ ${selected["$task"]} -eq 1 ]]; then
      needs_sudo=1
      return
    fi
  done
}

# ── Interactive picker ───────────────────────────────────────────────────────

declare -A selected
for task in "${available[@]}"; do selected["$task"]=1; done

cursor=0
needs_sudo=0
sudo_pass=""

# Alternate screen buffer preserves terminal scrollback
cleanup_screen() { tput rmcup 2>/dev/null || printf '\033[?1049l'; }
tput smcup 2>/dev/null || printf '\033[?1049h'
tput civis 2>/dev/null
trap cleanup_screen EXIT

# Buffered to a single printf '%b' call to avoid visible redraws
print_menu() {
  local el=$'\033[K'
  local buf='\033[H'

  buf+="${BOLD}╭─────────────────────────────────────────╮${NC}${el}\n"
  buf+="${BOLD}│        ${MENU_TITLE}${NC}${el}\n"
  buf+="${BOLD}╰─────────────────────────────────────────╯${NC}${el}\n${el}\n"

  local i=0
  for task in "${available[@]}"; do
    local name="${task#${PREFIX}:}"
    if [[ $i -eq $cursor ]]; then
      if [[ ${selected["$task"]} -eq 1 ]]; then
        buf+="  ${BOLD}▸${NC} ${T_PROGRAM}󰡖${NC} ${name}${el}\n"
      else
        buf+="  ${BOLD}▸${NC} ${T_ERROR}󰄱${NC} ${name}${el}\n"
      fi
    else
      if [[ ${selected["$task"]} -eq 1 ]]; then
        buf+="    ${T_PROGRAM}󰡖${NC} ${name}${el}\n"
      else
        buf+="    ${T_ERROR}󰄱${NC} ${name}${el}\n"
      fi
    fi
    ((i++)) || true
  done

  check_needs_sudo

  buf+="${el}\n"
  if [[ $needs_sudo -eq 1 ]]; then
    buf+="  ${T_WARNING}sudo required${NC} - password will be requested${el}\n"
  fi
  buf+="${el}\n"

  buf+="  ${BOLD}Space${NC}) Toggle    "
  buf+="${BOLD}a${NC}) Toggle all    "
  buf+="${T_OK}${BOLD}Enter${NC}) Confirm    "
  buf+="${T_ERROR}q${NC}) Quit${el}"
  buf+='\033[J'

  printf '%b' "$buf"
}

# Reads one keypress, translating arrow escape sequences to UP/DOWN/ESC
read_key() {
  local key
  IFS= read -rsn1 key
  if [[ "$key" == $'\033' ]]; then
    local seq
    IFS= read -rsn1 -t 0.01 seq
    if [[ "$seq" == "[" ]]; then
      IFS= read -rsn1 -t 0.01 seq
      case "$seq" in
      A) key="UP" ;; B) key="DOWN" ;; *) key="ESC" ;;
      esac
    else
      key="ESC"
    fi
  fi
  printf '%s' "$key"
}

# j/k, arrows, space, a, q/Esc, Enter — also Ctrl-Space and Q (undocumented)
while true; do
  print_menu
  key="$(read_key)"

  case "$key" in
  k | UP) ((cursor > 0)) && ((cursor--)) || true ;;
  j | DOWN) ((cursor < ${#available[@]} - 1)) && ((cursor++)) || true ;;
  " ")
    task="${available[$cursor]}"
    if [[ ${selected["$task"]} -eq 1 ]]; then
      selected["$task"]=0
    else
      selected["$task"]=1
    fi
    ;;
  a)
    all_on=1
    for task in "${available[@]}"; do
      [[ ${selected["$task"]} -eq 0 ]] && all_on=0 && break
    done
    for task in "${available[@]}"; do
      selected["$task"]=$((all_on ? 0 : 1))
    done
    ;;
  q | ESC)
    tput cnorm 2>/dev/null
    cleanup_screen
    trap - EXIT
    printf "${T_ERROR}Cancelled.${NC}\n"
    exit 1
    ;;
  "")
    # On confirm, prompt for sudo password if check_needs_sudo set the flag
    check_needs_sudo
    if [[ $needs_sudo -eq 1 ]]; then
      tput cnorm 2>/dev/null
      printf "\n\n  ${T_ERROR}sudo${NC} password: "
      read -rs sudo_pass
      if [[ -z "$sudo_pass" ]]; then
        tput civis 2>/dev/null
        continue
      fi
    fi
    break
    ;;
  esac
done

tput cnorm 2>/dev/null
cleanup_screen
trap - EXIT

# ── Build chosen list ────────────────────────────────────────────────────────

chosen=()
for task in "${available[@]}"; do
  [[ ${selected["$task"]} -eq 1 ]] && chosen+=("$task")
done
[[ ${#chosen[@]} -eq 0 ]] && die "Nothing selected."

# ── Launch tmux panes ────────────────────────────────────────────────────────

# Builds the shell command string that runs inside each tmux pane:
# prints a title, runs the task, shows 󰸞/󱎘 result, waits for keypress
make_cmd() {
  local task="$1"
  local name="${task#${PREFIX}:}"
  local cmd=""

  # Pre-authenticate sudo if password was provided and task needs it
  if [[ ${task_needs_sudo["$task"]:-0} -eq 1 ]] && [[ -n "$sudo_pass" ]]; then
    cmd="printf '%s\n' '$(printf '%s' "$sudo_pass" | sed "s/'/'\\\\''/g")' | sudo -S true 2>/dev/null; "
    cmd+="mise run $task"
  else
    cmd="mise run $task"
  fi

  printf 'printf "\\n\\033[1;36m── %s ──\\033[0m\\n"; %s && printf "\\n\\033[1;32m󰸞 %s succeeded\\033[0m\\n" || printf "\\n\\033[1;31m󱎘 %s failed\\033[0m\\n"; printf "\\n(press Enter to close)"; read -r -n 1' \
    "$name" "$cmd" "$name" "$name"
}

# Open a tmux window (or session if not in tmux), then split into tiled panes
inside_tmux=false
[[ -n "${TMUX:-}" ]] && inside_tmux=true

if $inside_tmux; then
  current_session="$(tmux display-message -p '#S')"
  tmux new-window -t "$current_session" -n "$TMUX_WINDOW" "$(make_cmd "${chosen[0]}")"
  target="$current_session:$TMUX_WINDOW"
else
  tmux kill-session -t "$TMUX_WINDOW" 2>/dev/null || true
  tmux new-session -d -s "$TMUX_WINDOW" -x "$(tput cols)" -y "$(tput lines)" \
    "$(make_cmd "${chosen[0]}")"
  target="$TMUX_WINDOW"
fi

# Each split rebalances with tiled layout to prevent "pane too small" errors
for task in "${chosen[@]:1}"; do
  tmux split-window -t "$target" "$(make_cmd "$task")"
  tmux select-layout -t "$target" tiled >/dev/null
done

tmux select-layout -t "$target" tiled >/dev/null
tmux select-pane -t "$target.{top-left}"
sudo_pass=""

if $inside_tmux; then
  tmux select-window -t "$target"
else
  tmux attach-session -t "$TMUX_WINDOW"
fi
