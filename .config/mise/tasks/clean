#!/usr/bin/env bash
#MISE description="Run all clean:* in parallel tmux panes"
#MISE quiet=true

set -euo pipefail
source "$(cd "$(dirname "$0")" && pwd)/utils/colors.sh"

EL=$'\033[K'
TMUX_WINDOW="mise-clean"

# в”Ђв”Ђ Gather available tasks в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

mapfile -t all_tasks < <(mise tasks ls --raw | awk '$1 ~ /^clean:.+/ && $1 != "clean" {print $1}')

available=()
for task in "${all_tasks[@]}"; do
  name="${task#clean:}"
  if command -v "$name" &>/dev/null; then
    available+=("$task")
  else
    printf "${YELLOW}${BOLD}[%s]${NC} not found, skipping.\n" "$task"
  fi
done
((${#available[@]})) || {
  printf "${RED}${BOLD}No cleanable tools found.${NC}\n" >&2
  exit 1
}

# в”Ђв”Ђ Interactive selection в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

declare -A selected
for task in "${available[@]}"; do selected["$task"]=1; done

cursor=0
max=$((${#available[@]} - 1))

cleanup() { tput cnorm rmcup 2>/dev/null || printf '\033[?25h\033[?1049l'; }
tput smcup civis 2>/dev/null || printf '\033[?1049h\033[?25l'
trap cleanup EXIT

print_menu() {
  local buf='\033[H'
  buf+="${BOLD}в•­в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•®${NC}${EL}\n"
  buf+="${BOLD}в”‚        Select clean tasks to run        в”‚${NC}${EL}\n"
  buf+="${BOLD}в•°в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•Ї${NC}${EL}\n${EL}\n"

  local i=0 ptr icon color
  for task in "${available[@]}"; do
    [[ $i -eq $cursor ]] && ptr="${BOLD}в–ё${NC} " || ptr="  "
    if [[ ${selected["$task"]} -eq 1 ]]; then
      icon="у°Ў–" color="${CYAN}${BOLD}"
    else
      icon="у°„±" color="${RED}${BOLD}"
    fi
    buf+="  ${ptr}${color}${icon}${NC} ${task#clean:}${EL}\n"
    ((i++)) || true
  done

  buf+="${EL}\n${EL}\n"
  buf+="  ${BOLD}Space${NC}) Toggle    "
  buf+="${BOLD}a${NC}) Toggle all    "
  buf+="${GREEN}${BOLD}Enter${NC}) Confirm    "
  buf+="${RED}${BOLD}q${NC}) Quit${EL}\033[J"

  printf '%b' "$buf"
}

read_key() {
  local key
  IFS= read -rsn1 key
  if [[ "$key" == $'\033' ]]; then
    local seq
    IFS= read -rsn1 -t 0.01 seq
    if [[ "$seq" == "[" ]]; then
      IFS= read -rsn1 -t 0.01 seq
      case "$seq" in A) key=UP ;; B) key=DOWN ;; *) key=ESC ;; esac
    else key=ESC; fi
  fi
  printf '%s' "$key"
}

toggle() {
  local t="${available[$cursor]}"
  selected["$t"]=$((selected["$t"] ^ 1))
}

while true; do
  print_menu
  case "$(read_key)" in
  k | UP) ((cursor > 0)) && ((cursor--)) || true ;;
  j | DOWN) ((cursor < max)) && ((cursor++)) || true ;;
  " ") toggle ;;
  a | A)
    local_all=1
    for task in "${available[@]}"; do [[ ${selected["$task"]} -eq 0 ]] && local_all=0 && break; done
    for task in "${available[@]}"; do selected["$task"]=$((local_all ^ 1)); done
    ;;
  q | ESC)
    cleanup
    trap - EXIT
    printf "${RED}${BOLD}Cancelled.${NC}\n"
    exit 1
    ;;
  "") break ;;
  esac
done

cleanup
trap - EXIT

# в”Ђв”Ђ Build chosen list в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

chosen=()
for task in "${available[@]}"; do
  [[ ${selected["$task"]} -eq 1 ]] && chosen+=("$task")
done
((${#chosen[@]})) || {
  printf "${RED}${BOLD}Nothing selected.${NC}\n" >&2
  exit 1
}

# в”Ђв”Ђ Launch tmux panes в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

make_cmd() {
  local task="$1" name="${task#clean:}"
  printf 'printf "\\n\\033[1;36mв”Ђв”Ђ %s в”Ђв”Ђ\\033[0m\\n"; mise run %s && printf "\\n\\033[1;32mвњ“ %s succeeded\\033[0m\\n" || printf "\\n\\033[1;31mвњ— %s failed\\033[0m\\n"; printf "\\n(press any key to close)"; read -r -n 1' \
    "$name" "$task" "$name" "$name"
}

if [[ -n "${TMUX:-}" ]]; then
  session="$(tmux display-message -p '#S')"
  tmux new-window -t "$session" -n "$TMUX_WINDOW" "$(make_cmd "${chosen[0]}")"
  target="$session:$TMUX_WINDOW"
else
  tmux kill-session -t "$TMUX_WINDOW" 2>/dev/null || true
  tmux new-session -d -s "$TMUX_WINDOW" -x "$(tput cols)" -y "$(tput lines)" \
    "$(make_cmd "${chosen[0]}")"
  target="$TMUX_WINDOW"
fi

for task in "${chosen[@]:1}"; do
  tmux split-window -t "$target" "$(make_cmd "$task")"
  tmux select-layout -t "$target" tiled >/dev/null
done
tmux select-layout -t "$target" tiled >/dev/null
tmux select-pane -t "$target.{top-left}"

[[ -n "${TMUX:-}" ]] && tmux select-window -t "$target" || tmux attach-session -t "$TMUX_WINDOW"
