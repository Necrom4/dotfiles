#!/usr/bin/env bash
#MISE description="Run all clean:* in parallel tmux panes"
#MISE quiet=true

set -euo pipefail

PREFIX="clean"
MENU_TITLE="Select clean tasks to run        │"
TMUX_WINDOW="mise-clean"

check_needs_sudo() {
  needs_sudo=0
  for task in "${available[@]}"; do
    if [[ "${task#clean:}" == "apt" ]] && [[ ${selected["$task"]} -eq 1 ]]; then
      needs_sudo=1
      return
    fi
  done
}

source "$(cd "$(dirname "$0")" && pwd)/utils/parallel-tasks"
