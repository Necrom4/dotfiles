#!/usr/bin/env zsh
#MISE description="Download Zeal/Dash docsets into $HOME/.local/share/Zeal/Zeal/docsets"
#MISE quiet=true
#USAGE arg "<docsets>" help="Docset names from api.zealdocs.org" var=#true var_min=1
#USAGE complete "docsets" run=#"zsh $HOME/.config/mise/tasks/install/docset --__complete"# descriptions=#true

source "${HOME}/.config/mise/tasks/utils/colors"

T_OK="${GREEN}${BOLD}"
T_WARN="${YELLOW}${BOLD}"
T_ERR="${RED}${BOLD}"
T_NAME="${CYAN}${BOLD}"

DOCSET_DIR="${HOME}/.local/share/Zeal/Zeal/docsets"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/mise-docsets"
INDEX_FILE="${CACHE_DIR}/index.json"
INDEX_URL="https://api.zealdocs.org/v1/docsets"
INDEX_TTL_SECONDS=$((24 * 60 * 60))   # 24h
# Zeal's canonical redirect endpoint — handles official Dash docsets,
# user-contributed docsets, and cheatsheets transparently by 302'ing to
# the closest kapeli.com mirror.
DOWNLOAD_URL_TEMPLATE="https://go.zealdocs.org/d/com.kapeli/%s/latest"

mkdir -p -- "$CACHE_DIR" "$DOCSET_DIR"

# ---------------------------------------------------------------------------
# Index management
# ---------------------------------------------------------------------------
fetch_index() {
  local now mtime age
  if [[ -s $INDEX_FILE ]]; then
    now=$(date +%s)
    mtime=$(stat -f %m -- "$INDEX_FILE" 2>/dev/null || stat -c %Y -- "$INDEX_FILE" 2>/dev/null || echo 0)
    age=$(( now - mtime ))
    (( age < INDEX_TTL_SECONDS )) && return 0
  fi
  curl -fsSL "$INDEX_URL" -o "${INDEX_FILE}.tmp" \
    && mv -- "${INDEX_FILE}.tmp" "$INDEX_FILE" \
    || { [[ -s $INDEX_FILE ]] && return 0; return 1 }
}

# ---------------------------------------------------------------------------
# Completion mode: print "name:title" lines and exit
# ---------------------------------------------------------------------------
if [[ ${1:-} == --__complete ]]; then
  fetch_index >/dev/null 2>&1 || exit 0
  jq -r '.[] | "\(.name):\(.title)"' "$INDEX_FILE" 2>/dev/null
  exit 0
fi

# ---------------------------------------------------------------------------
# Download / install logic
# ---------------------------------------------------------------------------
set -eu
eval "docsets=($usage_docsets)"

print -P "${BOLD}Refreshing docset index…${NC}"
fetch_index || { print -P "${T_ERR}[!] Failed to fetch docset index${NC}" >&2; exit 1 }

is_known_docset() {
  jq -e --arg n "$1" 'any(.[]; .name == $n)' "$INDEX_FILE" >/dev/null
}

install_one() {
  local name=$1
  local url tmpdir tarball

  if ! is_known_docset "$name"; then
    printf "${T_ERR}[!] Unknown docset: ${T_NAME}%s${NC}\n" "$name" >&2
    printf "    Try: ${BOLD}mise run install:docset${NC} <TAB> for completions\n" >&2
    return 1
  fi

  url=${DOWNLOAD_URL_TEMPLATE//\%s/$name}
  printf "${BOLD}↓ Downloading${NC} ${T_NAME}%s${NC}\n" "$name"
  tmpdir=$(mktemp -d) || return 1
  tarball="${tmpdir}/${name}.tgz"

  {
    if ! curl -fsSL --connect-timeout 10 --retry 2 -o "$tarball" "$url"; then
      printf "${T_ERR}[!] Download failed for ${T_NAME}%s${NC}\n" "$name" >&2
      return 1
    fi

    printf "${BOLD}↪ Extracting${NC} ${T_NAME}%s${NC}\n" "$name"
    if ! tar -xzf "$tarball" -C "$tmpdir"; then
      printf "${T_ERR}[!] Extraction failed for ${T_NAME}%s${NC} (downloaded file is not a valid tar.gz)\n" "$name" >&2
      return 1
    fi

    # Locate the *.docset directory inside the extracted tree.
    local extracted=("${tmpdir}"/*.docset(N))
    if (( ${#extracted} == 0 )); then
      printf "${T_ERR}[!] No .docset found in archive for ${T_NAME}%s${NC}\n" "$name" >&2
      return 1
    fi
    local src=${extracted[1]}
    local dest="${DOCSET_DIR}/${src:t}"

    rm -rf -- "$dest"
    mv -- "$src" "$dest"

    printf "${T_OK}[󰸞] Installed${NC} ${T_NAME}%s${NC} ${DIM}→ %s${NC}\n" "$name" "$dest"
  } always {
    rm -rf -- "$tmpdir"
  }
}

failed=()
for name in $docsets; do
  install_one "$name" || failed+=($name)
done

if (( ${#failed} )); then
  printf "\n${T_WARN}[!] ${#failed} docset(s) failed:${NC} %s\n" "${failed[*]}" >&2
  exit 1
fi
